# Azure Observer MCP Server — Environment Configuration
#
# Authentication (choose one method):
#
# Method 1: Azure CLI (simplest — just run `az login`)
#   No environment variables needed.
#
# Method 2: Service Principal
#   AZURE_TENANT_ID=your-tenant-id
#   AZURE_CLIENT_ID=your-client-id
#   AZURE_CLIENT_SECRET=your-client-secret

# Optional: Default subscription (falls back to first available)
# AZURE_SUBSCRIPTION_ID=your-subscription-id

# Optional: Restrict access to specific subscriptions (comma-separated)
# AZURE_ALLOWED_SUBSCRIPTIONS=sub-id-1,sub-id-2

# Optional: Enable dry-run mode (mutating tools describe changes without executing)
# AZURE_DRY_RUN=true

# Optional: Log level (debug, info, warn, error)
# LOG_LEVEL=info
